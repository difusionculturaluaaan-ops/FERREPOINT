generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String   @unique
  rfc       String   @unique
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  locations         Location[]
  users             User[]
  products          Product[]
  sales             Sale[]
  surtidoOrders     SurtidoOrder[]
  suppliers         Supplier[]
  stockMovements    StockMovement[]
  purchaseOrders    PurchaseOrder[]
  accountsReceivable AccountsReceivable[]
  accountsPayable   AccountsPayable[]
  cashCloses        CashClose[]
  deliveries        Delivery[]

  @@map("businesses")
}

model Location {
  id         String   @id @default(cuid())
  businessId String
  name       String
  clave      String
  address    String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products  Product[]
  sales     Sale[]
  surtidoOrders SurtidoOrder[]
  cashCloses CashClose[]
  deliveries Delivery[]

  @@unique([businessId, clave])
  @@index([businessId])
  @@map("locations")
}

model User {
  id         String   @id @default(cuid())
  businessId String
  email      String
  password   String
  name       String
  role       String   @default("vendedor")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales    Sale[]
  deliveries Delivery[]

  @@unique([email, businessId])
  @@index([businessId])
  @@map("users")
}

model ProductImage {
  id       String   @id @default(cuid())
  name     String
  category String
  imageUrl String
  createdAt DateTime @default(now())

  products Product[]

  @@unique([name, category])
  @@map("product_images")
}

model Supplier {
  id         String   @id @default(cuid())
  businessId String
  name       String
  contact    String?
  email      String?
  phone      String?
  address    String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]
  purchaseOrders PurchaseOrder[]
  accountsPayable AccountsPayable[]

  @@index([businessId])
  @@map("suppliers")
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  locationId String?
  imageId    String?
  supplierId String?
  clave      String
  name       String
  category   String
  costPrice  Float    @default(0)
  price      Float
  margin     Float    @default(0)
  stock      Int
  minStock   Int      @default(0)
  unit       String
  aisle      String?  // P01, P02, etc.
  level      String?  // N1, N2, N3
  side       String?  // DER, IZQ
  position   String?  // Pos 1, Pos 2, etc.
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  image    ProductImage? @relation(fields: [imageId], references: [id], onDelete: SetNull)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  saleItems SaleItem[]
  surtidoItems SurtidoItem[]
  stockMovements StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  deliveryItems DeliveryItem[]

  @@unique([businessId, clave])
  @@index([businessId])
  @@map("products")
}

model StockMovement {
  id        String   @id @default(cuid())
  businessId String
  productId String
  type      String   // 'entrada' | 'salida' | 'ajuste'
  qty       Int
  reason    String?
  reference String?
  createdAt DateTime @default(now())
  createdBy String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Sale {
  id             String   @id @default(cuid())
  businessId     String
  locationId     String
  folio          String
  vendorId       String
  clientName     String?
  clientRfc      String?
  paymentMethod  String
  comprobante    String
  subtotal       Float
  iva            Float
  total          Float
  createdAt      DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  vendor   User @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items    SaleItem[]
  surtidoOrder SurtidoOrder?
  cxc      AccountsReceivable?
  deliveries Delivery[]

  @@unique([businessId, folio])
  @@index([businessId])
  @@index([vendorId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  qty       Int
  price     Float
  subtotal  Float

  sale    Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("sale_items")
}

model SurtidoOrder {
  id         String   @id @default(cuid())
  businessId String
  locationId String
  saleId     String   @unique
  status     String   @default("pendiente")
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sale     Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  items    SurtidoItem[]

  @@index([businessId])
  @@index([status])
  @@map("surtido_orders")
}

model SurtidoItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  qty       Int
  surtido   Boolean  @default(false)

  order   SurtidoOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("surtido_items")
}

model PurchaseOrder {
  id        String   @id @default(cuid())
  businessId String
  supplierId String
  poNumber  String
  status    String   @default("pendiente") // pendiente, parcialmente_recibido, completado, cancelado
  total     Float
  reference String?
  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    PurchaseOrderItem[]
  cxp      AccountsPayable?

  @@unique([businessId, poNumber])
  @@index([businessId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  qty        Int
  qtyReceived Int    @default(0)

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("purchase_order_items")
}

model AccountsReceivable {
  id         String   @id @default(cuid())
  businessId String
  saleId     String   @unique
  clientName String
  amount     Float
  amountPaid Float    @default(0)
  dueDate    DateTime
  status     String   @default("pendiente") // pendiente, parcial, pagado
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale     Sale @relation(fields: [saleId], references: [id], onDelete: Restrict)
  payments PaymentReceivable[]

  @@index([businessId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_receivable")
}

model PaymentReceivable {
  id           String   @id @default(cuid())
  cxcId        String
  amount       Float
  paymentMethod String
  paymentDate  DateTime @default(now())

  cxc AccountsReceivable @relation(fields: [cxcId], references: [id], onDelete: Cascade)

  @@map("payment_receivable")
}

model AccountsPayable {
  id         String   @id @default(cuid())
  businessId String
  poId       String   @unique
  supplierId String
  amount     Float
  amountPaid Float    @default(0)
  dueDate    DateTime
  status     String   @default("pendiente") // pendiente, parcial, pagado
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  po       PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Restrict)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  payments PaymentPayable[]

  @@index([businessId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_payable")
}

model PaymentPayable {
  id           String   @id @default(cuid())
  cxpId        String
  amount       Float
  paymentMethod String
  paymentDate  DateTime @default(now())

  cxp AccountsPayable @relation(fields: [cxpId], references: [id], onDelete: Cascade)

  @@map("payment_payable")
}

model CashClose {
  id          String   @id @default(cuid())
  businessId  String
  locationId  String
  date        DateTime
  initialCash Float
  finalCash   Float
  totalSales  Int
  totalIngresos Float
  totalCosto  Float
  margin      Float
  difference  Float
  status      String   @default("cuadrado") // cuadrado, faltante, sobrante
  observations String?
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([businessId])
  @@index([locationId])
  @@index([date])
  @@map("cash_closes")
}

model Delivery {
  id                String   @id @default(cuid())
  businessId        String
  locationId        String
  driverId          String
  saleId            String
  clientName        String
  clientPhone       String
  address           String
  latitude          Float?
  longitude         Float?
  lastLocationUpdate DateTime?
  status            String   @default("pendiente") // pendiente, en_ruta, completado, cancelado
  completedAt       DateTime?
  createdAt         DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  driver   User @relation(fields: [driverId], references: [id], onDelete: Restrict)
  sale     Sale @relation(fields: [saleId], references: [id], onDelete: Restrict)
  items    DeliveryItem[]

  @@index([businessId])
  @@index([locationId])
  @@index([driverId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryItem {
  id         String   @id @default(cuid())
  deliveryId String
  productId  String
  qty        Int

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("delivery_items")
}
