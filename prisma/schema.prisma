generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String   @unique
  rfc       String   @unique
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  locations         Location[]
  users             User[]
  products          Product[]
  sales             Sale[]
  surtidoOrders     SurtidoOrder[]

  @@map("businesses")
}

model Location {
  id         String   @id @default(cuid())
  businessId String
  name       String
  clave      String
  address    String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products  Product[]
  sales     Sale[]
  surtidoOrders SurtidoOrder[]

  @@unique([businessId, clave])
  @@index([businessId])
  @@map("locations")
}

model User {
  id         String   @id @default(cuid())
  businessId String
  email      String
  password   String
  name       String
  role       String   @default("vendedor")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@unique([email, businessId])
  @@index([businessId])
  @@map("users")
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  locationId String?
  clave      String
  name       String
  category   String
  price      Float
  stock      Int
  minStock   Int      @default(0)
  unit       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  saleItems SaleItem[]
  surtidoItems SurtidoItem[]

  @@unique([businessId, clave])
  @@index([businessId])
  @@map("products")
}

model Sale {
  id             String   @id @default(cuid())
  businessId     String
  locationId     String
  folio          String
  vendorId       String
  clientName     String?
  clientRfc      String?
  paymentMethod  String
  comprobante    String
  subtotal       Float
  iva            Float
  total          Float
  createdAt      DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  vendor   User @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items    SaleItem[]
  surtidoOrder SurtidoOrder?

  @@unique([businessId, folio])
  @@index([businessId])
  @@index([vendorId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  qty       Int
  price     Float
  subtotal  Float

  sale    Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("sale_items")
}

model SurtidoOrder {
  id         String   @id @default(cuid())
  businessId String
  locationId String
  saleId     String   @unique
  status     String   @default("pendiente")
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sale     Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  items    SurtidoItem[]

  @@index([businessId])
  @@index([status])
  @@map("surtido_orders")
}

model SurtidoItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  qty       Int
  surtido   Boolean  @default(false)

  order   SurtidoOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("surtido_items")
}
